<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.projet_java.controller.MainController"
            prefHeight="600.0" prefWidth="800.0">
    <center>
        <VBox alignment="CENTER" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <Label text="Application de Gestion des Emplois du Temps" style="-fx-font-size: 24px;"/>
            <HBox alignment="CENTER" spacing="20.0">
                <Button fx:id="btnEtudiant" text="Connexion Étudiant"
                        prefWidth="200" prefHeight="50"/>
                <Button fx:id="btnEnseignant" text="Connexion Enseignant" 
                        prefWidth="200" prefHeight="50"/>
                <Button fx:id="btnAdministrateur" text="Connexion Administrateur" 
                        prefWidth="200" prefHeight="50"/>
            </HBox>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" >
            <Label text="© 2025 - Projet Java" />
        </HBox>
    </bottom>
</BorderPane>