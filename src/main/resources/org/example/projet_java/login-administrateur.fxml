<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.projet_java.controller.LoginAdministrateurController"
            prefHeight="400.0" prefWidth="600.0">
    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" bottom="20"/>
            </padding>
            <Label text="Connexion Administrateur" style="-fx-font-size: 20px;"/>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="15">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <HBox alignment="CENTER" spacing="10">
                <Label text="Identifiant:" prefWidth="100"/>
                <TextField fx:id="usernameField" prefWidth="250"/>
            </HBox>
            <HBox alignment="CENTER" spacing="10">
                <Label text="Mot de passe:" prefWidth="100"/>
                <PasswordField fx:id="passwordField" prefWidth="250"/>
            </HBox>
            <Label fx:id="messageLabel" textFill="RED"/>
            <HBox alignment="CENTER" spacing="20" padding="20">
                <Button text="Se connecter" onAction="#onLoginButtonClick" prefWidth="150"/>
                <Button text="Retour" onAction="#onBackButtonClick" prefWidth="150"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>